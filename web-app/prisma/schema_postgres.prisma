// PRODUCTION: PostgreSQL via Supabase.
// To use: copy this to schema.prisma, set DATABASE_URL + DIRECT_URL in .env, run prisma generate + migrate deploy.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(COUPLE)
  accounts      Account[]
  sessions      Session[]
  weddings      Wedding[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  SUPER_ADMIN
  COUPLE
  VENDOR
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Wedding {
  id                 String   @id @default(cuid())
  userId             String
  groomFirstName     String
  brideFirstName     String
  eventDate          DateTime?
  venueName          String?
  slug               String   @unique
  setupCompleted     Boolean  @default(false)
  estimatedGuests    Int?
  estimatedBudget    Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteSettings       SiteSettings?
  guests             Guest[]
  contentBlocks      ContentBlock[]
  galleryImages      GalleryImage[]
  agendaItems        AgendaItem[]
  tables             Table[]
  budgetCategories   BudgetCategory[]
  budgetItems        BudgetItem[]
  checklistGroups    ChecklistGroup[]
  checklistItems     ChecklistItem[]
  vendors            WeddingVendor[]
}

model SiteSettings {
  id             String   @id @default(cuid())
  weddingId      String   @unique
  siteTitle      String?
  sectionToggles Json?
  colors         Json?
  musicSettings  Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  wedding        Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Guest {
  id                  String   @id @default(cuid())
  weddingId           String
  name                String
  side                String
  whatsappCountryCode String?
  whatsappNumber      String?
  email               String?
  invitationType      String
  maxAllowedMembers   Int      @default(1)
  note                String?
  inviteToken         String   @unique @default(uuid())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  wedding             Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  rsvp                GuestRsvp?
  tableAssignments    TableAssignment[]
}

model GuestRsvp {
  id               String   @id @default(cuid())
  guestId          String   @unique
  status           String
  attendingCount   Int      @default(0)
  specialNote      String?
  liquorPreference String?
  mealPreference   String?
  updatedAt        DateTime @updatedAt

  guest            Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  members          GuestRsvpMember[]
}

model GuestRsvpMember {
  id               String   @id @default(cuid())
  guestRsvpId      String
  memberName       String
  typeOptional     String?

  guestRsvp        GuestRsvp @relation(fields: [guestRsvpId], references: [id], onDelete: Cascade)
}

model ContentBlock {
  id          String   @id @default(cuid())
  weddingId   String
  blockKey    String
  title       String?
  content     String?
  visible     Boolean  @default(true)
  sortOrder   Int      @default(0)

  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@unique([weddingId, blockKey])
}

model GalleryImage {
  id          String   @id @default(cuid())
  weddingId   String
  imageType   String
  imageUrl    String
  sortOrder   Int      @default(0)

  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model AgendaItem {
  id              String   @id @default(cuid())
  weddingId       String
  title           String
  eventTime       DateTime
  durationMinutes Int?
  description     String?
  iconKey         String?
  sortOrder       Int      @default(0)

  wedding         Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Table {
  id          String   @id @default(cuid())
  weddingId   String
  tableName   String
  capacity    Int
  sortOrder   Int      @default(0)

  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  assignments TableAssignment[]
}

model TableAssignment {
  id            String   @id @default(cuid())
  tableId       String
  guestId       String
  assignedCount Int      @default(1)

  table         Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  guest         Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
}

model BudgetCategory {
  id          String   @id @default(cuid())
  weddingId   String?
  name        String
  isDefault   Boolean  @default(false)

  wedding     Wedding? @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  items       BudgetItem[]
}

model BudgetItem {
  id              String   @id @default(cuid())
  weddingId       String
  categoryId      String
  title           String
  estimatedAmount Float?
  actualAmount    Float?
  paidAmount      Float?
  note            String?
  dueDate         DateTime?
  status          String?

  wedding         Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  category        BudgetCategory @relation(fields: [categoryId], references: [id])
}

model ChecklistGroup {
  id          String   @id @default(cuid())
  weddingId   String?
  title       String
  sortOrder   Int      @default(0)

  wedding     Wedding? @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  items       ChecklistItem[]
}

model ChecklistItem {
  id          String   @id @default(cuid())
  weddingId   String
  groupId     String
  title       String
  description String?
  isCompleted Boolean  @default(false)
  dueDate     DateTime?
  priority    String?
  reminderAt  DateTime?
  state       String?
  templateId  String?

  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  group       ChecklistGroup @relation(fields: [groupId], references: [id])
}

model WeddingVendor {
  id              String   @id @default(cuid())
  weddingId       String
  vendorProfileId String?
  customName      String?
  category        String
  phone           String?
  whatsapp        String?
  email           String?
  note            String?
  status          String?

  wedding         Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}
