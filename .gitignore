npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
credentials.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local automation and test artifacts
/.playwright-cli/
/test-results/
/output/
