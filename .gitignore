# dependencies
/node_modules
/web-app/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/web-app/.next/
/out/

# production
/build

# local database archives
/postgres.zip
/pgsql/

# misc
.DS_Store
*.pem

